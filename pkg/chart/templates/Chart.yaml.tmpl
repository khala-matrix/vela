apiVersion: v2
name: {{ .Name }}
description: Helm chart for {{ .Name }} generated by vela
type: application
version: 0.1.0
appVersion: "1.0.0"
{{- if .Dependencies }}
dependencies:
{{- range .Dependencies }}
  - name: {{ .ChartName }}
    version: "{{ .Version }}"
    repository: "{{ .Repository }}"
{{- end }}
{{- end }}
