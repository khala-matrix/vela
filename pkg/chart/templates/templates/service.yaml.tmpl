{{ "{{- range $name, $svc := .Values.services }}" }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ "{{ include \"chart.fullname\" $ }}" }}-{{ "{{ $name }}" }}
  labels:
    {{- "{{ include \"chart.labels\" $ | nindent 4 }}" }}
    app.kubernetes.io/component: {{ "{{ $name }}" }}
spec:
  type: ClusterIP
  ports:
    - port: {{ "{{ $svc.port }}" }}
      targetPort: {{ "{{ $svc.port }}" }}
      protocol: TCP
      name: http
  selector:
    {{- "{{ include \"chart.selectorLabels\" $ | nindent 4 }}" }}
    app.kubernetes.io/component: {{ "{{ $name }}" }}
{{ "{{- end }}" }}
