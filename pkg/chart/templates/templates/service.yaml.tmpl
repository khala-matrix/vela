apiVersion: v1
kind: Service
metadata:
  name: {{ "{{ include \"chart.fullname\" . }}" }}
  labels:
    {{- "{{ include \"chart.labels\" . | nindent 4 }}" }}
spec:
  type: ClusterIP
  ports:
    - port: {{ "{{ .Values.port }}" }}
      targetPort: {{ "{{ .Values.port }}" }}
      protocol: TCP
      name: http
  selector:
    {{- "{{ include \"chart.selectorLabels\" . | nindent 4 }}" }}
