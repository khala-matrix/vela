import type { NextConfig } from "next";

const nextConfig: NextConfig = {
  output: "standalone",
  basePath: "/{{ .Name }}",
  async rewrites() {
    return [
      {
        source: "/api/:path*",
        destination: `${process.env.API_BACKEND_URL || "http://{{ .Name }}-{{ .Name }}-backend:8000"}/api/:path*`,
      },
    ];
  },
};

export default nextConfig;
