#!/usr/bin/env bash
set -euo pipefail

REGISTRY="${REGISTRY:-{{ .Registry }}}"
TAG="${TAG:-latest}"
PLATFORM="${PLATFORM:-linux/amd64}"

if [ -n "${REGISTRY_USER:-}" ] && [ -n "${REGISTRY_PASSWORD:-}" ]; then
  echo "==> Logging in to ${REGISTRY%%/*}"
  echo "${REGISTRY_PASSWORD}" | {{ .BuildTool }} login "${REGISTRY%%/*}" -u "${REGISTRY_USER}" --password-stdin
else
  echo "==> REGISTRY_USER / REGISTRY_PASSWORD not set, skipping login"
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "==> Building {{ .Name }} (${PLATFORM})"
{{ .BuildTool }} {{ .BuildCmd }} --platform "${PLATFORM}" -t "${REGISTRY}/{{ .Name }}:${TAG}" "${SCRIPT_DIR}"

echo "==> Pushing image"
{{ .BuildTool }} push "${REGISTRY}/{{ .Name }}:${TAG}"

echo "==> Done"
